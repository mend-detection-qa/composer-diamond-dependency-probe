            "symfony/cache"
        ],
        "constraint_from_monolog": "^2.0 || ^3.0",
        "constraint_from_symfony_cache": "^1.1|^2|^3"
    },
    "mend_detection_expectations": {
        "psr_log_must_appear_exactly_once": true,
        "all_packages_must_appear": true,
        "source_for_all": "registry",
        "no_packages_dev": true,
        "failure_modes_exercised": [
